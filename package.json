{
  "name": "twenty-crm-mcp-server",
  "version": "0.3.0",
  "description": "A Model Context Protocol (MCP) server for Twenty CRM integration. Enables natural language interactions with your CRM data through Claude and other AI assistants.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "twenty-crm-mcp-server": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --inspect run src/index.ts",
    "test": "bun test",
    "smoke": "bun run smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "@types/bun": "latest"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "keywords": [
    "mcp",
    "twenty",
    "crm",
    "server",
    "claude",
    "ai",
    "assistant",
    "natural-language",
    "api",
    "integration",
    "typescript"
  ],
  "author": "mhenry3164",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mhenry3164/twenty-crm-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/mhenry3164/twenty-crm-mcp-server/issues"
  },
  "homepage": "https://github.com/mhenry3164/twenty-crm-mcp-server#readme"
}
